<script is:inline>
// ============ CONFIG ============
// Le formulaire est envoyé au service Postfix derrière nginx.
const ENDPOINT_URL = "/api/cadrage";

// ============ PROGRESS BAR ============
const form = document.getElementById('briefForm');
const progressFill = document.getElementById('progressFill');
const progressText = document.getElementById('progressText');

function updateProgress() {
  const allFields = form.querySelectorAll('input, textarea, select');
  const counted = new Set();
  let total = 0;
  let filled = 0;

  allFields.forEach(field => {
    const key = field.name || field.id;
    if (counted.has(key)) return;
    counted.add(key);
    total++;

    if (field.type === 'radio') {
      const checked = form.querySelector(`input[name="${field.name}"]:checked`);
      if (checked) filled++;
    } else if (field.type === 'checkbox') {
      const anyChecked = form.querySelector(`input[name="${field.name}"]:checked`);
      if (anyChecked) filled++;
    } else if (field.value && field.value.trim().length > 0) {
      filled++;
    }
  });

  const pct = Math.round((filled / total) * 100);
  progressFill.style.width = pct + '%';
  progressText.textContent = pct + '%';
}

form.addEventListener('input', updateProgress);
form.addEventListener('change', updateProgress);
updateProgress();

// ============ AUTO-SAVE (localStorage) ============
const STORAGE_KEY = 'webinti_quaisud_brief';

function saveForm() {
  const data = collectFormData();
  try {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
  } catch (e) { /* localStorage indispo */ }
}

function loadForm() {
  try {
    const saved = localStorage.getItem(STORAGE_KEY);
    if (!saved) return;
    const data = JSON.parse(saved);
    Object.entries(data).forEach(([name, value]) => {
      const fields = form.querySelectorAll(`[name="${name}"], [name="${name}[]"]`);
      fields.forEach(field => {
        if (field.type === 'radio' || field.type === 'checkbox') {
          if (Array.isArray(value)) {
            if (value.includes(field.value)) field.checked = true;
          } else if (field.value === value) {
            field.checked = true;
          }
        } else {
          field.value = value;
        }
      });
    });
    updateProgress();
  } catch (e) { /* parse error */ }
}

form.addEventListener('input', saveForm);
form.addEventListener('change', saveForm);
loadForm();

// ============ RÉSUMÉ LISIBLE ============
// Construit un récapitulatif texte à partir des libellés affichés,
// pour que l'email reçu soit directement lisible.
function buildSummary() {
  const lines = [];
  form.querySelectorAll('.section').forEach(section => {
    const title = section.querySelector('.section-title');
    lines.push('');
    lines.push('=== ' + (title ? title.textContent.trim() : '') + ' ===');

    section.querySelectorAll('.field').forEach(field => {
      const labelEl = field.querySelector('.q-label');
      const label = labelEl
        ? labelEl.textContent.replace(/\s*\*\s*$/, '').replace(/\s+/g, ' ').trim()
        : '(question)';

      const answers = [];
      field.querySelectorAll('input[type="text"], input[type="email"], input[type="number"], input[type="url"], input[type="date"], textarea, select').forEach(inp => {
        if (inp.value && inp.value.trim()) answers.push(inp.value.trim());
      });
      field.querySelectorAll('input[type="radio"]:checked, input[type="checkbox"]:checked').forEach(inp => {
        const opt = inp.closest('.option');
        answers.push(opt ? opt.textContent.replace(/\s+/g, ' ').trim() : inp.value);
      });

      lines.push('');
      lines.push('• ' + label);
      if (answers.length) {
        answers.forEach(a => lines.push('   → ' + a));
      } else {
        lines.push('   → (sans réponse)');
      }
    });
  });
  return lines.join('\n').trim();
}

// ============ COLLECT DATA ============
function collectFormData() {
  const formData = new FormData(form);
  const data = {};
  for (const [key, value] of formData.entries()) {
    if (key.endsWith('[]')) {
      const cleanKey = key.slice(0, -2);
      if (!data[cleanKey]) data[cleanKey] = [];
      data[cleanKey].push(value);
    } else if (data[key]) {
      // duplicates → array
      if (!Array.isArray(data[key])) data[key] = [data[key]];
      data[key].push(value);
    } else {
      data[key] = value;
    }
  }
  data._submitted_at = new Date().toISOString();
  data._source = 'quaisud_brief_v1';
  return data;
}

// ============ SUBMIT ============
const submitBtn = document.getElementById('submitBtn');
const statusMsg = document.getElementById('statusMsg');

form.addEventListener('submit', async (e) => {
  e.preventDefault();

  // Validate required
  const requiredFields = form.querySelectorAll('[required]');
  let firstInvalid = null;
  for (const field of requiredFields) {
    if (field.type === 'radio') {
      const group = form.querySelectorAll(`input[name="${field.name}"]`);
      const checked = Array.from(group).some(r => r.checked);
      if (!checked && !firstInvalid) firstInvalid = field;
    } else if (!field.value.trim() && !firstInvalid) {
      firstInvalid = field;
    }
  }

  if (firstInvalid) {
    showStatus('error', 'Merci de compléter les champs obligatoires marqués d\'un astérisque.');
    firstInvalid.scrollIntoView({ behavior: 'smooth', block: 'center' });
    firstInvalid.focus();
    return;
  }

  submitBtn.disabled = true;
  submitBtn.innerHTML = 'Envoi en cours… <span class="arrow">→</span>';

  const data = collectFormData();
  data._summary = buildSummary();

  try {
    const response = await fetch(ENDPOINT_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify(data)
    });
    if (!response.ok) throw new Error('HTTP ' + response.status);
    showStatus('success', 'Réponses envoyées avec succès. Je vous recontacte sous 72h avec une proposition détaillée.');
    localStorage.removeItem(STORAGE_KEY);
  } catch (err) {
    console.error(err);
    downloadJSON(data);
    showStatus('error', 'Erreur d\'envoi. Vos réponses ont été téléchargées en JSON, merci de les envoyer manuellement à contact@webinti.com.');
  } finally {
    submitBtn.disabled = false;
    submitBtn.innerHTML = 'Envoyer mes réponses <span class="arrow">→</span>';
  }
});

function showStatus(type, message) {
  statusMsg.className = 'status-msg show ' + type;
  statusMsg.textContent = message;
  statusMsg.scrollIntoView({ behavior: 'smooth', block: 'center' });
}

function downloadJSON(data) {
  const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = `cadrage-quaisud-${new Date().toISOString().slice(0,10)}.json`;
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  URL.revokeObjectURL(url);
}
</script>

