---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const faqGroups = [
  {
    title: 'Choisir Webinti',
    items: [
      {
        q: 'Pourquoi choisir Webinti pour mon projet ?',
        a: "Webinti combine cinq ans d'expertise Bubble.io (Champion Community 2024), plus de 80 produits livrés, et une approche IA-native intégrée dès le cadrage. Vous bénéficiez d'un interlocuteur senior unique, d'une méthode rodée en 4 étapes (Cadrage → Design → Build → Livraison) et d'un transfert technique complet à votre équipe en fin de mission."
      },
      {
        q: 'Quelle différence avec une agence web classique ?',
        a: "Nous livrons 3 à 5 fois plus vite grâce au NoCode (Bubble, FlutterFlow, Webflow), tout en conservant la qualité et la scalabilité d'un produit codé. Vous gardez la propriété complète du compte, du code et des données. Et nous embarquons l'IA dans vos workflows dès le départ — pas en option à 18 mois."
      },
      {
        q: 'Travaillez-vous avec des clients en dehors de la France ?',
        a: "Oui. Notre clientèle est principalement française et francophone (France, Belgique, Suisse, Canada), mais nous livrons régulièrement pour des startups européennes et internationales. Les échanges se font en français ou en anglais, en visio."
      }
    ]
  },
  {
    title: 'Budget & délais',
    items: [
      {
        q: 'Combien coûte la création d\'un site web ou d\'une application ?',
        a: "Indicatif : landing page Bubble 5 000 à 12 000 €, MVP SaaS 15 000 à 35 000 €, marketplace complète 40 000 à 80 000 €, app mobile MVP 20 000 à 40 000 €. Un atelier de cadrage gratuit (1 semaine) précise le budget exact avant tout engagement."
      },
      {
        q: 'En combien de temps livrez-vous un projet ?',
        a: "Une landing en 2 à 4 semaines, un MVP cadré en 4 à 8 semaines, un SaaS ou une marketplace complète en 8 à 16 semaines. La phase de cadrage initiale d'une semaine verrouille le périmètre et le calendrier avant de commencer à builder."
      },
      {
        q: 'Comment se déroule la facturation ?',
        a: "30 % à la signature du devis, 40 % à mi-projet (validation des maquettes ou du build), 30 % à la livraison. Pour les missions longues, nous facturons par jalons mensuels. Devis fermes — pas de dépassement non validé."
      }
    ]
  },
  {
    title: 'Stack & technologies',
    items: [
      {
        q: 'Quelles technologies utilisez-vous ?',
        a: "Stack principale : Bubble (web), FlutterFlow et Expo (mobile), Webflow et Framer (sites marketing), Stripe (paiements), Supabase et Algolia (data et recherche), Brevo (emailing), n8n et Make (automatisation), Claude (Anthropic) et OpenAI (assistants IA). Le choix se fait toujours selon votre cas d'usage, pas l'inverse."
      },
      {
        q: 'Le NoCode peut-il vraiment scaler ?',
        a: "Oui. Plusieurs apps Bubble dépassent le million d'utilisateurs. Nous concevons l'architecture data, les privacy rules et les workflows backend pour tenir la charge dès le départ — et nous migrons vers du code natif uniquement si votre trajectoire l'exige réellement."
      },
      {
        q: 'Intégrez-vous l\'IA dans les projets ?',
        a: "Oui, c'est notre signature. Chaque produit livré peut embarquer une couche IA pensée pour votre métier : agents Claude/OpenAI, automatisations Make/n8n, génération de contenu, qualification de leads, support client augmenté. Soit en intégration directe dans Bubble, soit via un backend Supabase ou Xano."
      }
    ]
  },
  {
    title: 'Propriété & maintenance',
    items: [
      {
        q: 'Qui possède le projet une fois livré ?',
        a: "Vous, à 100 %. Le compte Bubble, la base de données, les workflows, les domaines, les comptes Stripe et tiers : tout vous appartient. Nous transmettons les accès, la documentation technique et un loom de passation. Vous gardez la main, toujours."
      },
      {
        q: 'Proposez-vous des contrats de maintenance ?',
        a: "Oui. Forfaits mensuels à partir de 900 €/mois pour la maintenance, le monitoring, les hotfixes, les mises à jour iOS et Android et les petits ajouts. Sans engagement long. Idéal pour les apps en production sans équipe interne."
      },
      {
        q: 'Comment mesurez-vous le succès d\'un projet livré ?',
        a: "Nous définissons en cadrage les KPIs propres à votre produit : taux de conversion, temps de complétion d'un parcours, NPS, rétention, MRR. Nous installons les outils d'analytics (Plausible, Mixpanel ou solution interne RGPD) et fournissons un dashboard de pilotage."
      }
    ]
  },
  {
    title: 'Formation',
    items: [
      {
        q: 'Proposez-vous des formations ?',
        a: "Oui. Webinti Academy (academy.webinti.com) propose plus de 110 heures de contenu sur Bubble, FlutterFlow, Stripe et IA NoCode. Disponible à la carte ou en abonnement mensuel/annuel. Plus de 300 personnes formées, certaines via financement Qualiopi grâce à nos partenaires Illith et La Strat."
      },
      {
        q: 'Du mentoring 1:1 est-il possible ?',
        a: "Oui. Sessions d'1h en visio avec un dev senior pour débloquer un point dur, valider une architecture, ou recevoir un audit produit. Sur mesure, sans engagement. Réservation directe sur rdv.webinti.com/tim/mentoring-personnalise."
      }
    ]
  }
];

const allItems = faqGroups.flatMap((g) => g.items);

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: allItems.map((it) => ({
      '@type': 'Question',
      name: it.q,
      acceptedAnswer: { '@type': 'Answer', text: it.a }
    })),
  },
];
---
<BaseLayout
  title="FAQ — Webinti, agence NoCode et IA"
  description="Réponses aux questions fréquentes sur Webinti : tarifs, délais, stack technologique (Bubble, FlutterFlow, IA), propriété du projet, maintenance, formations."
  canonical="https://webinti.com/faq/"
  jsonLd={jsonLd}
>
  <Nav />
  <main>
    <article class="faqp">
      <header class="faqp-head">
        <span class="kicker">FAQ</span>
        <h1>Tout ce que vous voulez <em>savoir.</em></h1>
        <p class="lede">Les questions qu'on nous pose le plus souvent — sur les délais, les tarifs, la stack, la propriété, la maintenance et la formation.</p>
      </header>

      {faqGroups.map((group) => (
        <section class="faqp-group">
          <h2 class="faqp-group-title">{group.title}</h2>
          <div class="faqp-list">
            {group.items.map((it) => (
              <details class="faqp-item">
                <summary>{it.q}<span class="faqp-chev" aria-hidden="true">+</span></summary>
                <div class="faqp-a">{it.a}</div>
              </details>
            ))}
          </div>
        </section>
      ))}

      <section class="faqp-cta">
        <h3>Une question qui n'est pas listée ?</h3>
        <p>Réservez 30 minutes en visio — premier échange offert, on cadre votre besoin et on repart avec un plan.</p>
        <div class="faqp-cta-row">
          <a href="https://rdv.webinti.com/tim/parlons-de-votre-projet" target="_blank" rel="noopener" class="faqp-btn faqp-btn-primary">Réserver un créneau →</a>
          <a href="mailto:agence.webinti@gmail.com" class="faqp-btn faqp-btn-ghost">Nous écrire</a>
        </div>
      </section>
    </article>
  </main>
  <Footer />
</BaseLayout>

<style>
  .faqp{max-width:880px;margin:0 auto;padding:120px 32px 80px}
  .faqp-head{margin-bottom:56px;text-align:center}
  .faqp-head .kicker{display:inline-block;font-family:var(--mono);font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:var(--accent-2);padding:5px 11px;border-radius:999px;background:rgba(200,64,63,0.12);border:1px solid rgba(200,64,63,0.28);margin-bottom:18px}
  .faqp-head h1{font-size:clamp(40px,6vw,72px);font-weight:700;letter-spacing:-0.035em;line-height:1.02;color:var(--text);margin:0 0 16px;text-wrap:balance}
  .faqp-head h1 em{font-style:normal;background:linear-gradient(120deg,var(--accent-3),var(--accent-2));-webkit-background-clip:text;background-clip:text;color:transparent}
  .faqp-head .lede{font-size:17px;color:var(--text-dim);max-width:560px;margin:0 auto;line-height:1.55}

  .faqp-group{margin-bottom:48px}
  .faqp-group-title{font-size:13px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:var(--text-faint);margin:0 0 16px;padding-bottom:12px;border-bottom:1px solid var(--border);font-family:var(--mono)}
  .faqp-list{display:flex;flex-direction:column}

  .faqp-item{border-bottom:1px solid var(--border);padding:20px 0;transition:padding .2s}
  .faqp-item summary{display:flex;justify-content:space-between;align-items:flex-start;gap:24px;cursor:pointer;font-size:17px;font-weight:600;color:var(--text);letter-spacing:-0.01em;list-style:none;line-height:1.4}
  .faqp-item summary::-webkit-details-marker{display:none}
  .faqp-chev{font-size:24px;color:var(--text-faint);font-weight:300;transition:transform .25s ease;flex-shrink:0;margin-top:-2px}
  .faqp-item[open] .faqp-chev{transform:rotate(45deg);color:var(--accent-2)}
  .faqp-a{font-size:15.5px;line-height:1.7;color:var(--text-dim);margin-top:14px;padding-right:48px;text-wrap:pretty}

  .faqp-cta{margin-top:64px;padding:48px 32px;text-align:center;border-radius:20px;background:radial-gradient(circle at 30% 0%,rgba(200,64,63,0.18),transparent 60%),var(--panel);border:1px solid var(--border-strong)}
  .faqp-cta h3{font-size:24px;font-weight:600;letter-spacing:-0.015em;color:var(--text);margin:0 0 10px}
  .faqp-cta p{font-size:15px;color:var(--text-dim);margin:0 0 22px;max-width:480px;margin-inline:auto}
  .faqp-cta-row{display:flex;gap:10px;justify-content:center;flex-wrap:wrap}
  .faqp-btn{padding:12px 22px;border-radius:999px;font-weight:600;font-size:14px;display:inline-flex;align-items:center;gap:6px;transition:all .2s;border:1px solid transparent}
  .faqp-btn-primary{background:var(--text);color:#0B0B0F}
  .faqp-btn-primary:hover{transform:translateY(-1px);box-shadow:0 10px 30px rgba(255,255,255,0.08)}
  .faqp-btn-ghost{background:rgba(255,255,255,0.05);border-color:var(--border-strong);color:var(--text)}
  .faqp-btn-ghost:hover{background:rgba(255,255,255,0.08)}

  @media(max-width:760px){
    .faqp{padding:96px 20px 64px}
    .faqp-item summary{font-size:16px;gap:16px}
    .faqp-a{padding-right:0;font-size:15px}
    .faqp-cta{padding:36px 22px}
  }
</style>
