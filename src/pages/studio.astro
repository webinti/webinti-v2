---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/expertise.css';

const jsonLd = [{
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'Le studio Webinti',
  description: "Comment Webinti pense, conçoit et livre les produits : posture d'architecte, stack agnostique, IA dans le process et dans le produit.",
  url: 'https://webinti.com/studio/',
  about: { '@id': 'https://webinti.com/#organization' },
}];
---
<BaseLayout
  title="Le studio Webinti — Architecte produit, stack agnostique"
  description="Webinti est un studio produit augmenté par l'IA, basé dans le Var. Posture d'architecte, choix techno selon le projet (code généré par IA, NoCode, hybride). Pas d'agence-usine — équipe restreinte, interlocuteur senior unique."
  canonical="https://webinti.com/studio/"
  keywords="studio produit, agence ia, vibe coding agence, nocode france, architecte produit, claude code agence, cursor agence, webinti about"
  jsonLd={jsonLd}
>
  <Nav />
  <main>
    <section class="ex-hero">
      <div class="ex-hero-bg"><div class="ex-hero-grid"></div></div>
      <div class="container">
        <div class="ex-hero-inner">
          <nav class="crumb"><a href="/">Accueil</a><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg><span>Le studio</span></nav>
          <div class="ex-eyebrow"><span class="dot"></span>Studio · Posture · Méthode</div>
          <h1 class="ex-title">Studio, pas <em>agence-usine</em>.</h1>
          <p class="ex-sub">Webinti est un studio produit augmenté par l'IA, basé dans le Var. Une équipe restreinte, un interlocuteur senior unique, des choix techno faits sur mérite. On ne vend pas Bubble, on ne vend pas du code — on livre votre produit.</p>
        </div>
      </div>
    </section>

    <section class="sec">
      <div class="container">
        <div class="sec-head">
          <div class="sec-kicker">Posture</div>
          <h2 class="sec-title">Architecte produit, <em>pas exécutant</em>.</h2>
          <p class="sec-lede">La majorité des agences exécutent un cahier des charges. On préfère challenger le brief, simplifier l'archi, identifier le MVP minimum viable. Notre valeur n'est pas dans la prod brute — elle est dans les bonnes décisions, prises tôt.</p>
        </div>
        <div class="feat-grid">
          <div class="feat"><div class="feat-t">Cadrage rigoureux</div><div class="feat-d">Une semaine d'atelier avant tout chiffrage. On élimine 30% de scope inutile en moyenne.</div></div>
          <div class="feat"><div class="feat-t">Stack adaptative</div><div class="feat-d">Bubble, Next.js + Cursor, FlutterFlow, hybride — on choisit l'outil qui livre votre produit le mieux.</div></div>
          <div class="feat"><div class="feat-t">Transmission complète</div><div class="feat-d">Documentation, accès, formation. À la fin, votre équipe interne opère sans nous si besoin.</div></div>
        </div>
      </div>
    </section>

    <section class="sec">
      <div class="container">
        <div class="sec-head">
          <div class="sec-kicker">Méthode</div>
          <h2 class="sec-title">L'IA dans le produit. <em>Et dans le process.</em></h2>
          <p class="sec-lede">On développe avec Cursor et Claude Code, ce qui multiplie notre vélocité par 3 sans dégrader la qualité. Et on intègre l'IA dans les produits livrés — quand elle apporte une vraie valeur, pas comme gimmick marketing.</p>
        </div>
        <div class="steps">
          <div class="step"><div class="step-t">Cadrage</div><div class="step-d">Atelier produit, archi data, MVP minimum, devis ferme. 1 semaine, gratuit pour les projets sérieux.</div></div>
          <div class="step"><div class="step-t">Design</div><div class="step-d">Maquettes Figma, prototype cliquable, validation produit avant tout build.</div></div>
          <div class="step"><div class="step-t">Build</div><div class="step-d">Sprints d'1 semaine, démos hebdo, ajustements continus. Accès Linear/Notion pour vous.</div></div>
          <div class="step"><div class="step-t">Livraison</div><div class="step-d">Tests, mise en production, transmission, formation, maintenance optionnelle.</div></div>
        </div>
      </div>
    </section>

    <section class="sec">
      <div class="container">
        <div class="sec-head">
          <div class="sec-kicker">Reconnaissance</div>
          <h2 class="sec-title">Un parcours, pas un pitch.</h2>
          <p class="sec-lede">Tim Polfliet construit depuis 2020. Distinction Bubble Champion Community 2024 et mention par le CEO de Bubble.io en keynote. Mais surtout : 80+ produits livrés, 300+ personnes formées, et la même méthode appliquée chaque semaine.</p>
        </div>
        <div class="feat-grid">
          <div class="feat"><div class="feat-t">+80 produits livrés</div><div class="feat-d">Marketplaces, SaaS, CRM, e-commerce, apps mobiles, agents IA. Voir le <a href="/showcase/">showcase</a>.</div></div>
          <div class="feat"><div class="feat-t">+300 personnes formées</div><div class="feat-d">Bubble, FlutterFlow, Stripe, IA NoCode — via Webinti Academy et nos partenaires Qualiopi.</div></div>
          <div class="feat"><div class="feat-t">Bubble Champion 2024</div><div class="feat-d">Distinction officielle Bubble.io · Cité par Emmanuel Straschnov en keynote.</div></div>
        </div>
      </div>
    </section>

    <section class="ex-cta">
      <div class="container">
        <div class="ex-cta-inner">
          <h2>On parle de votre projet ?</h2>
          <p>30 minutes en visio, premier échange offert. On cadre, on chiffre, vous décidez.</p>
          <a href="https://rdv.webinti.com/tim/parlons-de-votre-projet" target="_blank" rel="noopener" class="btn btn-primary">Réserver un créneau<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M9 7h8v8"/></svg></a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
