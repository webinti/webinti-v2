  <script>
    // Reveal on scroll
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add('in');
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.12 });
    document.querySelectorAll('.reveal').forEach((el) => io.observe(el));

    // Pricing toggle — swap grids
    const osGrid = document.getElementById('pricing-os');
    const subGrid = document.getElementById('pricing-sub');
    document.querySelectorAll<HTMLButtonElement>('.pricing-toggle button').forEach((b) => {
      b.addEventListener('click', () => {
        document.querySelectorAll('.pricing-toggle button').forEach((x) => x.classList.remove('active'));
        b.classList.add('active');
        const tab = b.dataset.tab;
        if (osGrid && subGrid) {
          osGrid.hidden = tab !== 'oneshot';
          subGrid.hidden = tab !== 'sub';
        }
      });
    });

    // Formations tab filter
    document.querySelectorAll<HTMLButtonElement>('.form-tabs button').forEach((b) => {
      b.addEventListener('click', () => {
        document.querySelectorAll('.form-tabs button').forEach((x) => x.classList.remove('active'));
        b.classList.add('active');
        const cat = b.dataset.cat;
        document.querySelectorAll<HTMLElement>('.formation').forEach((f) => {
          if (cat === 'all' || f.dataset.cat === cat) f.classList.remove('hidden');
          else f.classList.add('hidden');
        });
      });
    });

    // Hero ember scroll intensifier
    (function () {
      const hero = document.querySelector<HTMLElement>('.hero');
      if (!hero) return;
      let ticking = false;
      function update() {
        const r = hero!.getBoundingClientRect();
        const vh = window.innerHeight;
        const p = Math.min(1, Math.max(0, 1 - (r.bottom / (vh + r.height * 0.5))));
        const op = 0.5 + p * 0.45;
        const sc = 1 + p * 0.2;
        hero!.style.setProperty('--ember-opacity', op.toFixed(3));
        hero!.style.setProperty('--ember-scale', sc.toFixed(3));
        ticking = false;
      }
      window.addEventListener('scroll', () => {
        if (!ticking) { requestAnimationFrame(update); ticking = true; }
      }, { passive: true });
      update();
    })();

    // Smooth scroll
    document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach((a) => {
      a.addEventListener('click', (e) => {
        const id = a.getAttribute('href') || '';
        if (id.length > 1) {
          const t = document.querySelector(id);
          if (t) { e.preventDefault(); t.scrollIntoView({ behavior: 'smooth', block: 'start' }); }
        }
      });
    });

    // Dashboard cursor tour
    (function () {
      const cursor = document.getElementById('aw-cursor');
      const tip = document.getElementById('aw-tooltip');
      const main = document.querySelector<HTMLElement>('.aw-main');
      if (!cursor || !main || !tip) return;
      const targets = [
        { sel: '.dash-stat:nth-child(2)', text: "Taux d'ouverture · 5%" },
        { sel: '.dash-pipe:nth-child(1)', text: '3 264 leads · Nouveau' },
        { sel: '.dash-agent:nth-child(2)', text: 'Follow-up Agent' },
        { sel: '.dash-tbl tr:nth-child(2)', text: 'E.P.C. · 2 clics' },
        { sel: '.dash-stat:nth-child(4)', text: 'Pipeline · 1 732 contacts' },
      ];
      let i = 0;
      function step() {
        const t = targets[i % targets.length];
        const el = main!.querySelector<HTMLElement>(t.sel);
        if (!el) { i++; setTimeout(step, 800); return; }
        const mr = main!.getBoundingClientRect();
        const er = el.getBoundingClientRect();
        const x = er.left - mr.left + er.width * 0.35;
        const y = er.top - mr.top + er.height * 0.5;
        cursor!.style.transform = `translate(${x}px,${y}px)`;
        document.querySelectorAll('.hoverable.cursor-active').forEach((e) => e.classList.remove('cursor-active'));
        setTimeout(() => {
          el.classList.add('hoverable', 'cursor-active');
          tip!.textContent = t.text;
          tip!.style.left = (x + 22) + 'px';
          tip!.style.top = (y + 10) + 'px';
          tip!.classList.add('on');
        }, 1100);
        setTimeout(() => {
          tip!.classList.remove('on');
          el.classList.remove('cursor-active');
        }, 2400);
        i++;
        setTimeout(step, 2800);
      }
      setTimeout(step, 1500);
    })();
  </script>
