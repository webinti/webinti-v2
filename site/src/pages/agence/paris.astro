---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/expertise.css';

const jsonLd = [{
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'Webinti — Agence NoCode et IA Paris',
  description: "Studio produit augmenté par l'IA intervenant sur Paris et Île-de-France. Apps web et mobile sur-mesure, MVP, marketplaces, IA. Stack adaptée : code, NoCode, ou hybride.",
  url: 'https://webinti.com/agence/paris/',
  parentOrganization: { '@id': 'https://webinti.com/#organization' },
  areaServed: { '@type': 'City', name: 'Paris', containedInPlace: { '@type': 'AdministrativeArea', name: 'Île-de-France' } },
  serviceArea: { '@type': 'GeoCircle', geoMidpoint: { '@type': 'GeoCoordinates', latitude: 48.8566, longitude: 2.3522 }, geoRadius: 50000 },
  knowsAbout: ['Bubble.io', 'Claude Code', 'Cursor', 'Next.js', 'FlutterFlow', 'NoCode', 'IA', 'Marketplace', 'SaaS'],
  inLanguage: 'fr-FR',
}];
---
<BaseLayout
  title="Agence NoCode et IA à Paris — Webinti, studio produit"
  description="Agence française basée en France et active sur Paris : conception, développement et livraison d'apps web et mobile augmentées par l'IA. Bubble, Claude Code, Next.js, FlutterFlow. +80 produits livrés."
  canonical="https://webinti.com/agence/paris/"
  keywords="agence nocode paris, agence ia paris, agence bubble paris, agence flutterflow paris, dev nocode paris, créer app paris, marketplace paris"
  jsonLd={jsonLd}
>
  <Nav />
  <main>
    <section class="ex-hero">
      <div class="ex-hero-bg"><div class="ex-hero-grid"></div></div>
      <div class="container">
        <div class="ex-hero-inner">
          <nav class="crumb"><a href="/">Accueil</a><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg><span>Agence Paris</span></nav>
          <div class="ex-eyebrow"><span class="dot"></span>Agence NoCode &amp; IA · Paris &amp; Île-de-France</div>
          <h1 class="ex-title">Studio produit pour <em>startups parisiennes</em>.</h1>
          <p class="ex-sub">Webinti accompagne les fondateurs et CTO basés à Paris pour concevoir, développer et livrer leurs apps web et mobiles. On intervient en visio ou sur place. La stack s'adapte à votre projet — Bubble, Claude Code, Next.js, FlutterFlow.</p>
          <div class="ex-cta-row">
            <a href="https://rdv.webinti.com/tim/parlons-de-votre-projet" target="_blank" rel="noopener" class="btn btn-primary">Réserver un échange<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M9 7h8v8"/></svg></a>
            <a href="/showcase/" class="btn btn-ghost">Voir les projets</a>
          </div>
        </div>
      </div>
    </section>

    <section class="sec">
      <div class="container">
        <div class="sec-head">
          <div class="sec-kicker">Pour qui à Paris</div>
          <h2 class="sec-title">Pensé pour les <em>fondateurs pressés</em>.</h2>
          <p class="sec-lede">L'écosystème parisien lance plus de startups que toute autre métropole française. Time-to-market, MVP propre, IA dans le produit dès le jour 1 — voilà ce qu'on livre.</p>
        </div>
        <div class="feat-grid">
          <div class="feat"><div class="feat-t">Startups Station F &amp; Station 13</div><div class="feat-d">MVP en 6-8 semaines pour valider votre marché avant la levée de fonds.</div></div>
          <div class="feat"><div class="feat-t">Scale-ups Pré-Saint-Gervais</div><div class="feat-d">Apps internes, panels admin, marketplaces. On embarque dans votre process Linear/Notion.</div></div>
          <div class="feat"><div class="feat-t">PME établies Île-de-France</div><div class="feat-d">Refonte d'app legacy, intégration IA dans le produit, formation des équipes internes.</div></div>
        </div>
      </div>
    </section>

    <section class="sec">
      <div class="container">
        <div class="sec-head">
          <div class="sec-kicker">Pourquoi Webinti</div>
          <h2 class="sec-title">Agence française, posture senior, tech invisible.</h2>
          <p class="sec-lede">Une équipe restreinte, un interlocuteur senior unique, un cadrage gratuit avant chiffrage, et un transfert technique complet. La stack qui sert votre projet — pas l'inverse.</p>
        </div>
        <div class="tools-strip">
          <span class="tool-chip"><span class="tool-dot"></span>Claude Code</span>
          <span class="tool-chip"><span class="tool-dot"></span>Cursor</span>
          <span class="tool-chip"><span class="tool-dot"></span>Next.js</span>
          <span class="tool-chip"><span class="tool-dot"></span>Supabase</span>
          <span class="tool-chip"><span class="tool-dot"></span>Bubble</span>
          <span class="tool-chip"><span class="tool-dot"></span>FlutterFlow</span>
          <span class="tool-chip"><span class="tool-dot"></span>Stripe</span>
          <span class="tool-chip"><span class="tool-dot"></span>Anthropic Claude</span>
        </div>
      </div>
    </section>

    <section class="ex-cta">
      <div class="container">
        <div class="ex-cta-inner">
          <h2>Vous êtes basé à Paris ?</h2>
          <p>30 minutes en visio offertes, ou un café près de Châtelet — on cadre votre projet.</p>
          <a href="https://rdv.webinti.com/tim/parlons-de-votre-projet" target="_blank" rel="noopener" class="btn btn-primary">Réserver un créneau<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M9 7h8v8"/></svg></a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
