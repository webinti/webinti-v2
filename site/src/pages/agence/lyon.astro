---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/expertise.css';

const jsonLd = [{
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'Webinti — Agence NoCode et IA Lyon',
  description: "Studio produit augmenté par l'IA pour startups et PME de Lyon et de la région Auvergne-Rhône-Alpes. Apps web et mobile sur-mesure, Bubble, Claude Code, Next.js, FlutterFlow.",
  url: 'https://webinti.com/agence/lyon/',
  parentOrganization: { '@id': 'https://webinti.com/#organization' },
  areaServed: { '@type': 'City', name: 'Lyon', containedInPlace: { '@type': 'AdministrativeArea', name: 'Auvergne-Rhône-Alpes' } },
  serviceArea: { '@type': 'GeoCircle', geoMidpoint: { '@type': 'GeoCoordinates', latitude: 45.7640, longitude: 4.8357 }, geoRadius: 50000 },
  knowsAbout: ['Bubble.io', 'Claude Code', 'Cursor', 'Next.js', 'FlutterFlow', 'NoCode', 'IA', 'Marketplace', 'SaaS'],
  inLanguage: 'fr-FR',
}];
---
<BaseLayout
  title="Agence NoCode et IA à Lyon — Webinti, studio produit"
  description="Studio produit français pour startups et PME de Lyon et Auvergne-Rhône-Alpes. Apps web et mobile augmentées par l'IA. Bubble, Claude Code, Next.js, FlutterFlow. +80 produits livrés."
  canonical="https://webinti.com/agence/lyon/"
  keywords="agence nocode lyon, agence ia lyon, agence bubble lyon, dev nocode lyon, créer app lyon, marketplace lyon, agence flutterflow lyon"
  jsonLd={jsonLd}
>
  <Nav />
  <main>
    <section class="ex-hero">
      <div class="ex-hero-bg"><div class="ex-hero-grid"></div></div>
      <div class="container">
        <div class="ex-hero-inner">
          <nav class="crumb"><a href="/">Accueil</a><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg><span>Agence Lyon</span></nav>
          <div class="ex-eyebrow"><span class="dot"></span>Agence NoCode &amp; IA · Lyon &amp; Rhône-Alpes</div>
          <h1 class="ex-title">Studio produit pour <em>startups lyonnaises</em>.</h1>
          <p class="ex-sub">L'écosystème lyonnais bouge — H7, Boost, Tubà, Pulsalys, et les pépites de la French Tech Lyon. Webinti accompagne fondateurs et CTO pour concevoir, développer et livrer apps web et mobiles, à distance ou sur place.</p>
          <div class="ex-cta-row">
            <a href="https://rdv.webinti.com/tim/parlons-de-votre-projet" target="_blank" rel="noopener" class="btn btn-primary">Réserver un échange<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M9 7h8v8"/></svg></a>
            <a href="/showcase/" class="btn btn-ghost">Voir les projets</a>
          </div>
        </div>
      </div>
    </section>

    <section class="sec">
      <div class="container">
        <div class="sec-head">
          <div class="sec-kicker">Pour qui à Lyon</div>
          <h2 class="sec-title">De Confluence à <em>Part-Dieu</em>.</h2>
          <p class="sec-lede">Lyon a sa propre dynamique : moins de bruit qu'à Paris, plus d'industries lourdes (santé, biotech, manufacturing) qui veulent s'augmenter à l'IA. On adapte notre approche à votre tissu local.</p>
        </div>
        <div class="feat-grid">
          <div class="feat"><div class="feat-t">SaaS B2B industriels</div><div class="feat-d">Outils métier, dashboards data, intégrations ERP — avec une couche IA pertinente.</div></div>
          <div class="feat"><div class="feat-t">Startups deep-tech</div><div class="feat-d">MVP rapides pour valider un marché avant la série A. Cadrage strict, livraison 6-12 semaines.</div></div>
          <div class="feat"><div class="feat-t">PME en transformation</div><div class="feat-d">Refonte d'outils internes, automatisations, intégration agents IA dans les workflows existants.</div></div>
        </div>
      </div>
    </section>

    <section class="sec">
      <div class="container">
        <div class="sec-head">
          <div class="sec-kicker">Notre stack</div>
          <h2 class="sec-title">La techno qui sert votre projet.</h2>
          <p class="sec-lede">On ne vous vend pas un outil par défaut. Selon votre cas, c'est code généré par IA, NoCode visuel, ou hybride.</p>
        </div>
        <div class="tools-strip">
          <span class="tool-chip"><span class="tool-dot"></span>Claude Code</span>
          <span class="tool-chip"><span class="tool-dot"></span>Cursor</span>
          <span class="tool-chip"><span class="tool-dot"></span>Next.js</span>
          <span class="tool-chip"><span class="tool-dot"></span>Supabase</span>
          <span class="tool-chip"><span class="tool-dot"></span>Bubble</span>
          <span class="tool-chip"><span class="tool-dot"></span>FlutterFlow</span>
          <span class="tool-chip"><span class="tool-dot"></span>Stripe</span>
          <span class="tool-chip"><span class="tool-dot"></span>Anthropic Claude</span>
        </div>
      </div>
    </section>

    <section class="ex-cta">
      <div class="container">
        <div class="ex-cta-inner">
          <h2>Vous êtes basé à Lyon ?</h2>
          <p>30 minutes en visio offertes pour cadrer votre projet — devis ferme sous 5 jours.</p>
          <a href="https://rdv.webinti.com/tim/parlons-de-votre-projet" target="_blank" rel="noopener" class="btn btn-primary">Réserver un créneau<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M9 7h8v8"/></svg></a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
