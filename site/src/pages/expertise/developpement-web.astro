---
import ExpertiseLayout from '../../layouts/ExpertiseLayout.astro';

const faqs = [
  {
    "q": "Quelle différence avec une agence classique ?",
    "a": "Nous livrons 3 à 5× plus vite grâce au NoCode, tout en gardant la qualité et la scalabilité d'un produit codé. Vous économisez sur le TTM et vous gardez la main sur le produit."
  },
  {
    "q": "Le NoCode peut-il vraiment scaler ?",
    "a": "Oui. Bubble héberge des produits à plusieurs millions de users. Nous choisissons la stack en fonction de votre volume, et nous migrons si besoin."
  },
  {
    "q": "Qui possède le projet ?",
    "a": "Vous. Le compte, le code, la data : tout vous appartient. Nous n'utilisons jamais de stack propriétaire qui vous enferme."
  },
  {
    "q": "Combien coûte un projet type ?",
    "a": "Une landing : 5-12k€. Une app SaaS MVP : 15-35k€. Une marketplace complète : 40-80k€. Devis précis après atelier de cadrage gratuit."
  }
];
---
<ExpertiseLayout
  title="Développement Web — Webinti"
  description="Sites, CRM, Intranet, Marketplace, E-Commerce — nous concevons et livrons n'importe quel projet digital, plus vite que le code traditionnel, sans compromis sur la performance."
  canonical="https://webinti.com/expertise/developpement-web/"
  serviceName="Webinti — Développement Web"
  faqs={faqs}
>
<section class="ex-hero">
  <div class="ex-hero-bg"><div class="ex-hero-grid"></div></div>
  <div class="container">
    <div class="ex-hero-inner">
      <nav class="crumb" aria-label="Fil d'Ariane">
        <a href="/">Accueil</a>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
        <a href="/expertise/developpement-web/">Expertise</a>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
        <span>Développement Web</span>
      </nav>
      <div class="ex-eyebrow"><span class="dot"></span>Développement Web</div>
      <h1 class="ex-title">Développement <em>Web</em><br>pensé pour livrer vite.</h1>
      <p class="ex-sub">Sites, CRM, Intranet, Marketplace, E-Commerce — nous concevons et livrons n'importe quel projet digital, plus vite que le code traditionnel, sans compromis sur la performance.</p>
      <div class="ex-cta-row">
        <a href="https://rdv.webinti.com/tim/parlons-de-votre-projet" target="_blank" rel="noopener" class="btn btn-primary">Parler à un expert
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M9 7h8v8"/></svg>
        </a>
        <a href="#process" class="btn btn-ghost">Voir la méthode</a>
      </div>
      <div class="ex-meta">
    <div class="ex-meta-item">
      <span class="ex-meta-label">Délai moyen</span>
      <span class="ex-meta-value">4 à 12 semaines</span>
    </div>
    <div class="ex-meta-item">
      <span class="ex-meta-label">Stack</span>
      <span class="ex-meta-value">Bubble · Webflow · Framer</span>
    </div>
    <div class="ex-meta-item">
      <span class="ex-meta-label">Projets livrés</span>
      <span class="ex-meta-value">+80 produits</span>
    </div></div>
    </div>
  </div>
</section>

<section class="sec">
  <div class="container">
    <div class="sec-head">
      <div class="sec-kicker">Ce que l'on fait</div>
      <h2 class="sec-title">Un catalogue pensé pour les produits qui doivent sortir.</h2>
      <p class="sec-lede">Des briques éprouvées, que l'on combine selon votre contexte — et que l'on ajuste selon votre stack et vos contraintes.</p>
    </div>
    <div class="feat-grid">
    <div class="feat">
      <div class="feat-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><path d="M3 5h18v14H3z"/><path d="M3 9h18"/><circle cx="6" cy="7" r="0.6" fill="currentColor"/></svg></div>
      <div class="feat-t">Sites & Landing</div>
      <div class="feat-d">Pages marketing qui convertissent, optimisées SEO et Core Web Vitals.</div>
    </div>
    <div class="feat">
      <div class="feat-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg></div>
      <div class="feat-t">Applications SaaS</div>
      <div class="feat-d">Produits complets avec authentification, paiements, back-office et API.</div>
    </div>
    <div class="feat">
      <div class="feat-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><path d="M3 9l1-5h16l1 5"/><path d="M4 9v11h16V9"/><path d="M9 13h6"/></svg></div>
      <div class="feat-t">Marketplace</div>
      <div class="feat-d">Plateformes multi-vendeurs avec gestion des commissions, Stripe Connect, KYC.</div>
    </div>
    <div class="feat">
      <div class="feat-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="M3 10h18"/><path d="M7 15h3"/></svg></div>
      <div class="feat-t">CRM & Intranet</div>
      <div class="feat-d">Outils internes sur-mesure, branchés sur vos data sources et vos équipes.</div>
    </div>
    <div class="feat">
      <div class="feat-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><circle cx="9" cy="20" r="1.5"/><circle cx="17" cy="20" r="1.5"/><path d="M3 4h3l2.5 11h11L22 7H6"/></svg></div>
      <div class="feat-t">E-Commerce</div>
      <div class="feat-d">Boutiques haut de gamme : Shopify Plus, Webflow Ecomm ou stack headless.</div>
    </div>
    <div class="feat">
      <div class="feat-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><path d="M21 12a9 9 0 1 1-3-6.7"/><polyline points="21 3 21 9 15 9"/></svg></div>
      <div class="feat-t">Refontes</div>
      <div class="feat-d">Reprise de projets legacy vers une stack moderne, sans casser la production.</div>
    </div></div>
  </div>
</section>

<section class="sec" id="process">
  <div class="container">
    <div class="sec-head">
      <div class="sec-kicker">Méthode</div>
      <h2 class="sec-title">4 étapes, zéro surprise.</h2>
      <p class="sec-lede">Un process carré, des jalons clairs, une communication hebdomadaire.</p>
    </div>
    <div class="steps">
    <div class="step">
      <div class="step-t">Cadrage</div>
      <div class="step-d">Atelier UX, objectifs, KPIs, architecture.</div>
    </div>
    <div class="step">
      <div class="step-t">Design</div>
      <div class="step-d">Figma, prototype cliquable validé avant dev.</div>
    </div>
    <div class="step">
      <div class="step-t">Build</div>
      <div class="step-d">Sprints hebdo, démos, ajustements continus.</div>
    </div>
    <div class="step">
      <div class="step-t">Livraison</div>
      <div class="step-d">Tests, mise en prod, transmission, maintenance.</div>
    </div></div>
  </div>
</section>

<section class="sec">
  <div class="container">
    <div class="sec-head">
      <div class="sec-kicker">Stack</div>
      <h2 class="sec-title">Les bons outils pour le bon projet.</h2>
      <p class="sec-lede">Nous choisissons la stack en fonction de vos contraintes — pas l'inverse.</p>
    </div>
    <div class="tools-strip"><span class="tool-chip"><span class="tool-dot"></span>Bubble</span><span class="tool-chip"><span class="tool-dot"></span>Webflow</span><span class="tool-chip"><span class="tool-dot"></span>Framer</span><span class="tool-chip"><span class="tool-dot"></span>Shopify</span><span class="tool-chip"><span class="tool-dot"></span>Supabase</span><span class="tool-chip"><span class="tool-dot"></span>n8n</span><span class="tool-chip"><span class="tool-dot"></span>Xano</span><span class="tool-chip"><span class="tool-dot"></span>Claude</span></div>
  </div>
</section>

<section class="sec">
  <div class="container">
    <div class="sec-head">
      <div class="sec-kicker">FAQ</div>
      <h2 class="sec-title">Questions fréquentes.</h2>
    </div>
    <div class="faq">
    <details class="faq-item">
      <summary class="faq-q">Quelle différence avec une agence classique ?</summary>
      <div class="faq-a">Nous livrons 3 à 5× plus vite grâce au NoCode, tout en gardant la qualité et la scalabilité d'un produit codé. Vous économisez sur le TTM et vous gardez la main sur le produit.</div>
    </details>
    <details class="faq-item">
      <summary class="faq-q">Le NoCode peut-il vraiment scaler ?</summary>
      <div class="faq-a">Oui. Bubble héberge des produits à plusieurs millions de users. Nous choisissons la stack en fonction de votre volume, et nous migrons si besoin.</div>
    </details>
    <details class="faq-item">
      <summary class="faq-q">Qui possède le projet ?</summary>
      <div class="faq-a">Vous. Le compte, le code, la data : tout vous appartient. Nous n'utilisons jamais de stack propriétaire qui vous enferme.</div>
    </details>
    <details class="faq-item">
      <summary class="faq-q">Combien coûte un projet type ?</summary>
      <div class="faq-a">Une landing : 5-12k€. Une app SaaS MVP : 15-35k€. Une marketplace complète : 40-80k€. Devis précis après atelier de cadrage gratuit.</div>
    </details></div>
  </div>
</section>

<section class="ex-cta">
  <div class="container">
    <div class="ex-cta-inner">
      <h2>Parlons de votre projet.</h2>
      <p>30 minutes en visio pour cadrer votre besoin, estimer le budget, et repartir avec un plan clair.</p>
      <a href="https://rdv.webinti.com/tim/parlons-de-votre-projet" target="_blank" rel="noopener" class="btn btn-primary">Réserver un créneau
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M9 7h8v8"/></svg>
      </a>
    </div>
  </div>
</section>
</ExpertiseLayout>
