---
import ExpertiseLayout from '../../layouts/ExpertiseLayout.astro';

const faqs = [
  {
    "q": "Les tutoriels sont-ils vraiment gratuits ?",
    "a": "Oui. L'intégralité des vidéos de base est gratuite. Certains cursus avancés ou fichiers sources premium sont payants."
  },
  {
    "q": "Où les trouver ?",
    "a": "YouTube pour la plupart, plus une plateforme privée pour les membres avec exercices et correction. Inscription gratuite."
  },
  {
    "q": "À quel rythme de nouveautés ?",
    "a": "2 à 4 nouvelles vidéos par semaine, un live par mois, une série de fond par trimestre."
  },
  {
    "q": "Puis-je suggérer des sujets ?",
    "a": "Oui. Via le Discord ou le formulaire de contact : on priorise en fonction des votes."
  }
];
---
<ExpertiseLayout
  title="Tutoriels — Webinti"
  description="Des vidéos à votre disposition pour monter en compétence à votre rythme. NoCode, IA, automation : tout ce qu'il faut pour passer de l'idée au produit en ligne."
  canonical="https://webinti.com/expertise/tutoriels/"
  serviceName="Webinti — Tutoriels"
  faqs={faqs}
>
<section class="ex-hero">
  <div class="ex-hero-bg"><div class="ex-hero-grid"></div></div>
  <div class="container">
    <div class="ex-hero-inner">
      <nav class="crumb" aria-label="Fil d'Ariane">
        <a href="/">Accueil</a>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
        <a href="/expertise/developpement-web/">Expertise</a>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
        <span>Tutoriels</span>
      </nav>
      <div class="ex-eyebrow"><span class="dot"></span>Vidéos · Gratuit</div>
      <h1 class="ex-title"><em>Tutoriels</em><br>pensé pour livrer vite.</h1>
      <p class="ex-sub">Des vidéos à votre disposition pour monter en compétence à votre rythme. NoCode, IA, automation : tout ce qu'il faut pour passer de l'idée au produit en ligne.</p>
      <div class="ex-cta-row">
        <a href="https://rdv.webinti.com/tim/parlons-de-votre-projet" target="_blank" rel="noopener" class="btn btn-primary">Parler à un expert
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M9 7h8v8"/></svg>
        </a>
        <a href="#process" class="btn btn-ghost">Voir la méthode</a>
      </div>
      <div class="ex-meta">
    <div class="ex-meta-item">
      <span class="ex-meta-label">Vidéos disponibles</span>
      <span class="ex-meta-value">+200 tutos</span>
    </div>
    <div class="ex-meta-item">
      <span class="ex-meta-label">Durée totale</span>
      <span class="ex-meta-value">90+ heures</span>
    </div>
    <div class="ex-meta-item">
      <span class="ex-meta-label">Tarif</span>
      <span class="ex-meta-value">Gratuit</span>
    </div></div>
    </div>
  </div>
</section>

<section class="sec">
  <div class="container">
    <div class="sec-head">
      <div class="sec-kicker">Ce que l'on fait</div>
      <h2 class="sec-title">Un catalogue pensé pour les produits qui doivent sortir.</h2>
      <p class="sec-lede">Des briques éprouvées, que l'on combine selon votre contexte — et que l'on ajuste selon votre stack et vos contraintes.</p>
    </div>
    <div class="feat-grid">
    <div class="feat">
      <div class="feat-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><polygon points="7 5 19 12 7 19"/></svg></div>
      <div class="feat-t">Démarrer sur Bubble</div>
      <div class="feat-d">Série de 20 vidéos pour couvrir les bases. Idéal pour débuter de zéro.</div>
    </div>
    <div class="feat">
      <div class="feat-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 9h6v6H9z"/></svg></div>
      <div class="feat-t">Cas pratiques</div>
      <div class="feat-d">Clone d'Airbnb, Uber, LinkedIn : on reconstruit les apps que vous connaissez.</div>
    </div>
    <div class="feat">
      <div class="feat-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><path d="M12 2a5 5 0 0 0-5 5c0 1.5.7 2.9 1.8 3.8A5 5 0 0 0 7 17h10a5 5 0 0 0-1.8-6.2A5 5 0 0 0 12 2z"/></svg></div>
      <div class="feat-t">IA & Claude</div>
      <div class="feat-d">Intégrer un agent IA dans vos projets, prompt engineering, RAG.</div>
    </div>
    <div class="feat">
      <div class="feat-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><circle cx="6" cy="6" r="2"/><circle cx="18" cy="6" r="2"/><circle cx="12" cy="18" r="2"/><path d="M6 8v3a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2V8"/></svg></div>
      <div class="feat-t">Automation n8n</div>
      <div class="feat-d">Connecter Stripe, Slack, Notion, Claude. Workflows gagne-temps.</div>
    </div>
    <div class="feat">
      <div class="feat-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><circle cx="12" cy="12" r="9"/><path d="M12 3v18"/></svg></div>
      <div class="feat-t">Design & Figma</div>
      <div class="feat-d">Passer d'une idée à un design pro, puis convertir en produit Bubble.</div>
    </div>
    <div class="feat">
      <div class="feat-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="3" fill="currentColor"/></svg></div>
      <div class="feat-t">Lives hebdo</div>
      <div class="feat-d">Chaque semaine : un live avec un expert pour répondre à vos questions.</div>
    </div></div>
  </div>
</section>

<section class="sec" id="process">
  <div class="container">
    <div class="sec-head">
      <div class="sec-kicker">Méthode</div>
      <h2 class="sec-title">4 étapes, zéro surprise.</h2>
      <p class="sec-lede">Un process carré, des jalons clairs, une communication hebdomadaire.</p>
    </div>
    <div class="steps">
    <div class="step">
      <div class="step-t">Choisir</div>
      <div class="step-d">Parcourez la bibliothèque par niveau ou par outil.</div>
    </div>
    <div class="step">
      <div class="step-t">Regarder</div>
      <div class="step-d">Vidéos courtes, denses, avec fichiers sources téléchargeables.</div>
    </div>
    <div class="step">
      <div class="step-t">Pratiquer</div>
      <div class="step-d">Reproduisez en temps réel. On vous aide sur le Discord.</div>
    </div>
    <div class="step">
      <div class="step-t">Progresser</div>
      <div class="step-d">Passez aux modules avancés ou intégrez un cursus.</div>
    </div></div>
  </div>
</section>

<section class="sec">
  <div class="container">
    <div class="sec-head">
      <div class="sec-kicker">Stack</div>
      <h2 class="sec-title">Les bons outils pour le bon projet.</h2>
      <p class="sec-lede">Nous choisissons la stack en fonction de vos contraintes — pas l'inverse.</p>
    </div>
    <div class="tools-strip"><span class="tool-chip"><span class="tool-dot"></span>Bubble</span><span class="tool-chip"><span class="tool-dot"></span>FlutterFlow</span><span class="tool-chip"><span class="tool-dot"></span>n8n</span><span class="tool-chip"><span class="tool-dot"></span>Claude</span><span class="tool-chip"><span class="tool-dot"></span>Figma</span><span class="tool-chip"><span class="tool-dot"></span>Shopify</span><span class="tool-chip"><span class="tool-dot"></span>Webflow</span></div>
  </div>
</section>

<section class="sec">
  <div class="container">
    <div class="sec-head">
      <div class="sec-kicker">FAQ</div>
      <h2 class="sec-title">Questions fréquentes.</h2>
    </div>
    <div class="faq">
    <details class="faq-item">
      <summary class="faq-q">Les tutoriels sont-ils vraiment gratuits ?</summary>
      <div class="faq-a">Oui. L'intégralité des vidéos de base est gratuite. Certains cursus avancés ou fichiers sources premium sont payants.</div>
    </details>
    <details class="faq-item">
      <summary class="faq-q">Où les trouver ?</summary>
      <div class="faq-a">YouTube pour la plupart, plus une plateforme privée pour les membres avec exercices et correction. Inscription gratuite.</div>
    </details>
    <details class="faq-item">
      <summary class="faq-q">À quel rythme de nouveautés ?</summary>
      <div class="faq-a">2 à 4 nouvelles vidéos par semaine, un live par mois, une série de fond par trimestre.</div>
    </details>
    <details class="faq-item">
      <summary class="faq-q">Puis-je suggérer des sujets ?</summary>
      <div class="faq-a">Oui. Via le Discord ou le formulaire de contact : on priorise en fonction des votes.</div>
    </details></div>
  </div>
</section>

<section class="ex-cta">
  <div class="container">
    <div class="ex-cta-inner">
      <h2>Parlons de votre projet.</h2>
      <p>30 minutes en visio pour cadrer votre besoin, estimer le budget, et repartir avec un plan clair.</p>
      <a href="https://rdv.webinti.com/tim/parlons-de-votre-projet" target="_blank" rel="noopener" class="btn btn-primary">Réserver un créneau
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M9 7h8v8"/></svg>
      </a>
    </div>
  </div>
</section>
</ExpertiseLayout>
