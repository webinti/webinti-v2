---
import ExpertiseLayout from '../../layouts/ExpertiseLayout.astro';

const faqs = [
  {
    "q": "Les formations sont-elles finançables ?",
    "a": "Oui, via nos organismes partenaires certifiés Qualiopi : Illith et La Strat. Le financement OPCO et le plan de développement des compétences passent par eux. Parlez-nous de votre projet pour qu'on vous oriente vers la bonne structure."
  },
  {
    "q": "Distanciel ou présentiel ?",
    "a": "Les deux. Sessions en visio avec classe virtuelle, ou intra-entreprise dans vos locaux en France et Europe."
  },
  {
    "q": "Quel niveau requis ?",
    "a": "Aucun prérequis technique pour les modules fondamentaux. Les cursus avancés supposent une première expérience NoCode ou produit."
  },
  {
    "q": "Combien coûte une formation ?",
    "a": "Module court (12-20h) : 1200-2400€ HT par personne. Cursus complet 80h : 4900€ HT. Tarifs intra sur devis."
  }
];
---
<ExpertiseLayout
  title="Formations — Webinti"
  description="+ de 110 heures de formation pour développer votre projet. Cursus Bubble, FlutterFlow, n8n et IA, animés par des praticiens en activité."
  canonical="https://webinti.com/expertise/formations/"
  serviceName="Webinti — Formations"
  faqs={faqs}
>
<section class="ex-hero">
  <div class="ex-hero-bg"><div class="ex-hero-grid"></div></div>
  <div class="container">
    <div class="ex-hero-inner ex-hero-center">
      <div class="ex-eyebrow"><span class="dot"></span>Financement possible via Illith & La Strat</div>
      <h1 class="ex-title"><em>Formations</em><br>pensé pour livrer vite.</h1>
      <p class="ex-sub">+ de 110 heures de formation pour développer votre projet. Cursus Bubble, FlutterFlow, n8n et IA, animés par des praticiens en activité.</p>
      <div class="ex-cta-row">
        <a href="https://rdv.webinti.com/tim/parlons-de-votre-projet" target="_blank" rel="noopener" class="btn btn-primary">Parler à un expert
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M9 7h8v8"/></svg>
        </a>
        <a href="#process" class="btn btn-ghost">Voir la méthode</a>
      </div>
      <div class="ex-meta">
    <div class="ex-meta-item">
      <span class="ex-meta-label">Heures de formation</span>
      <span class="ex-meta-value">+110 heures</span>
    </div>
    <div class="ex-meta-item">
      <span class="ex-meta-label">Format</span>
      <span class="ex-meta-value">Distanciel · Intra</span>
    </div>
    <div class="ex-meta-item">
      <span class="ex-meta-label">Niveau</span>
      <span class="ex-meta-value">Débutant à avancé</span>
    </div></div>
    </div>
  </div>
</section>

<section class="sec" id="catalogue">
  <div class="container">
    <div class="sec-head">
      <div class="sec-kicker">Catalogue</div>
      <h2 class="sec-title">Apprendre <em>vite et bien.</em></h2>
      <p class="sec-lede">Des parcours conçus avec des devs seniors, testés en conditions réelles, et mis à jour à chaque release majeure des outils.</p>
    </div>

    <div class="form-tabs">
      <button class="active" data-cat="all">Tout</button>
      <button data-cat="bubble"><span class="ft-dot" style="background:#0082F4"></span>Bubble</button>
      <button data-cat="flutterflow"><span class="ft-dot" style="background:#5D5DFF"></span>FlutterFlow</button>
      <button data-cat="stripe"><span class="ft-dot" style="background:#635BFF"></span>Stripe</button>
      <button data-cat="ia"><span class="ft-dot" style="background:#D97757"></span>IA</button>
      <button data-cat="mentoring"><span class="ft-dot" style="background:#B6F26A"></span>Mentoring</button>
    </div>

    <div class="formations">
      <a href="https://academy.webinti.com" class="formation" data-cat="bubble" style="--fc:#0082F4;--fc2:#0B4A8C">
        <div class="form-sheen"></div>
        <div class="form-ico-wrap"><div class="form-ico">B</div></div>
        <div class="form-arrow">↗</div>
        <div class="form-tag"><span></span>Bubble — Fondamentaux</div>
        <div class="form-title">Maîtriser Bubble<br>de A à Z</div>
        <p class="form-desc">40h de contenu structuré. Data types, workflows, API, privacy rules, performances — tout pour livrer en production.</p>
        <div class="form-meta"><span>40h</span><span>12 modules</span><span>Certificat</span></div>
      </a>

      <a href="https://academy.webinti.com" class="formation" data-cat="flutterflow" style="--fc:#5D5DFF;--fc2:#2E2E99">
        <div class="form-sheen"></div>
        <div class="form-ico-wrap"><div class="form-ico">F</div></div>
        <div class="form-arrow">↗</div>
        <div class="form-tag"><span></span>FlutterFlow — Mobile</div>
        <div class="form-title">Concevoir une app<br>iOS + Android</div>
        <p class="form-desc">Architecture mobile, Firebase, publication stores. On construit ensemble une app marketplace complète.</p>
        <div class="form-meta"><span>24h</span><span>8 modules</span><span>Projet final</span></div>
      </a>

      <a href="https://academy.webinti.com" class="formation" data-cat="stripe" style="--fc:#635BFF;--fc2:#302BAD">
        <div class="form-sheen"></div>
        <div class="form-ico-wrap"><div class="form-ico">S</div></div>
        <div class="form-arrow">↗</div>
        <div class="form-tag"><span></span>Stripe — Paiement</div>
        <div class="form-title">Maîtriser Stripe<br>sur Bubble</div>
        <p class="form-desc">Abonnements, Connect, webhooks, factures. L'environnement paiement pro pour votre produit Bubble.</p>
        <div class="form-meta"><span>12h</span><span>6 modules</span><span>Templates</span></div>
      </a>

      <a href="https://academy.webinti.com" class="formation" data-cat="bubble" style="--fc:#00A8A0;--fc2:#004F4B">
        <div class="form-sheen"></div>
        <div class="form-ico-wrap"><div class="form-ico">M</div></div>
        <div class="form-arrow">↗</div>
        <div class="form-tag"><span></span>Marketplace — Avancé</div>
        <div class="form-title">Construire un clone<br>type Vinted</div>
        <p class="form-desc">Niveau avancé. Matching, paiement split, chat temps réel, modération. Parfait pour un Bubble confirmé.</p>
        <div class="form-meta"><span>18h</span><span>10 modules</span><span>Code source</span></div>
      </a>

      <a href="https://academy.webinti.com" class="formation" data-cat="ia" style="--fc:#D97757;--fc2:#7A3A22">
        <div class="form-sheen"></div>
        <div class="form-ico-wrap"><div class="form-ico">◆</div></div>
        <div class="form-arrow">↗</div>
        <div class="form-tag"><span></span>IA & Automatisation</div>
        <div class="form-title">Agents IA dans<br>vos produits NoCode</div>
        <p class="form-desc">Nouveau. Claude, OpenAI, Make, n8n. Intégrer un agent utile dans votre produit existant en 2 semaines.</p>
        <div class="form-meta"><span>16h</span><span>7 modules</span><span>Nouveau</span></div>
      </a>

      <a href="https://rdv.webinti.com/tim/mentoring-personnalise" target="_blank" rel="noopener" class="formation" data-cat="mentoring" style="--fc:#B6F26A;--fc2:#4E6A1E">
        <div class="form-sheen"></div>
        <div class="form-ico-wrap"><div class="form-ico" style="color:#000">★</div></div>
        <div class="form-arrow">↗</div>
        <div class="form-tag"><span></span>Mentoring 1:1</div>
        <div class="form-title">Un expert<br>sur votre projet</div>
        <p class="form-desc">Sessions d'1h avec un dev senior. Débloquer un point dur, valider une archi, recevoir un audit produit.</p>
        <div class="form-meta"><span>1h/session</span><span>Sur mesure</span><span>Expert senior</span></div>
      </a>
    </div>
  </div>
</section>

<section class="sec" id="pricing">
  <div class="container">
    <div class="sec-head">
      <div class="sec-kicker">Tarifs</div>
      <h2 class="sec-title">Un prix clair. <em>Aucune surprise.</em></h2>
      <p class="sec-lede">Formations one-shot, ou abonnement mensuel pour accéder à tout le catalogue. TVA incluse.</p>
    </div>

    <div class="pricing-wrap">
      <div class="pricing-toggle">
        <button class="active" data-tab="oneshot">One-shot</button>
        <button data-tab="sub">Abonnement</button>
      </div>

      <div class="pricing-grid" id="pricing-os">
        <div class="price">
          <div class="price-name">Stripe</div>
          <div class="price-title">Maîtriser Stripe sur Bubble</div>
          <div class="price-amount"><b>90</b><sup>€</sup><span class="per">TTC</span></div>
          <div class="price-old">150€ — prix plein</div>
          <ul class="price-feats">
            <li>12h de contenu vidéo</li>
            <li>6 modules pratiques</li>
            <li>Templates Stripe fournis</li>
            <li>Accès Discord privé</li>
            <li>Mises à jour à vie</li>
          </ul>
          <a href="https://academy.webinti.com" class="price-cta">Commencer</a>
        </div>

        <div class="price">
          <div class="price-name">FlutterFlow</div>
          <div class="price-title">App mobile iOS + Android</div>
          <div class="price-amount"><b>250</b><sup>€</sup><span class="per">TTC</span></div>
          <div class="price-old">500€ — prix plein</div>
          <ul class="price-feats">
            <li>24h de formation</li>
            <li>Projet marketplace complet</li>
            <li>Publication App Store & Play</li>
            <li>Intégration Firebase</li>
            <li>Mentoring 1h inclus</li>
          </ul>
          <a href="https://academy.webinti.com" class="price-cta">Commencer</a>
        </div>

        <div class="price featured">
          <div class="price-badge">Le + choisi</div>
          <div class="price-name">Bubble</div>
          <div class="price-title">Bubble — fondamentaux complets</div>
          <div class="price-amount"><b>500</b><sup>€</sup><span class="per">TTC</span></div>
          <div class="price-old">950€ — prix plein</div>
          <ul class="price-feats">
            <li>40h structurées</li>
            <li>12 modules progressifs</li>
            <li>2 projets complets</li>
            <li>Revue de code 1:1</li>
            <li>Certificat Webinti</li>
          </ul>
          <a href="https://academy.webinti.com" class="price-cta">Commencer</a>
        </div>

        <div class="price">
          <div class="price-name">IA & Automatisation</div>
          <div class="price-title">Agents IA dans vos produits</div>
          <div class="price-amount"><b>190</b><sup>€</sup><span class="per">TTC</span></div>
          <div class="price-old">350€ — prix plein</div>
          <ul class="price-feats">
            <li>16h de formation</li>
            <li>Claude, OpenAI, Make, n8n</li>
            <li>3 projets d'intégration</li>
            <li>Prompts & templates</li>
            <li>Discord communauté</li>
          </ul>
          <a href="https://academy.webinti.com" class="price-cta">Commencer</a>
        </div>
      </div>

      <div class="pricing-grid" id="pricing-sub" hidden>
        <div class="price">
          <div class="price-name">Mensuel</div>
          <div class="price-title">Tout le catalogue, sans engagement</div>
          <div class="price-amount"><b>39</b><sup>€</sup><span class="per">/mois</span></div>
          <div class="price-note">Résiliable à tout moment</div>
          <ul class="price-feats">
            <li>Accès à <b style="color:var(--text)">toutes</b> les formations</li>
            <li>Nouveaux contenus chaque mois</li>
            <li>Discord privé + événements</li>
            <li>Mentoring 30min / mois</li>
            <li>Sans engagement</li>
          </ul>
          <a href="https://academy.webinti.com" class="price-cta">S'abonner</a>
        </div>

        <div class="price featured">
          <div class="price-badge">Économisez 17%</div>
          <div class="price-name">Annuel</div>
          <div class="price-title">Tout le catalogue — 12 mois</div>
          <div class="price-amount"><b>390</b><sup>€</sup><span class="per">/an</span></div>
          <div class="price-note">≈ 32,50€/mois — 2 mois offerts</div>
          <ul class="price-feats">
            <li>Accès à <b style="color:var(--text)">toutes</b> les formations</li>
            <li>Nouvelles sorties en avant-première</li>
            <li>Discord privé + événements</li>
            <li>Mentoring 1h / mois</li>
            <li>Certificats Webinti inclus</li>
          </ul>
          <a href="https://academy.webinti.com" class="price-cta">Choisir l'annuel</a>
        </div>

        <div class="price">
          <div class="price-name">Équipe</div>
          <div class="price-title">Jusqu'à 5 membres</div>
          <div class="price-amount"><b>990</b><sup>€</sup><span class="per">/an</span></div>
          <div class="price-old">Pour les agences et startups</div>
          <ul class="price-feats">
            <li>5 sièges inclus</li>
            <li>Tableau de bord admin</li>
            <li>Mentoring 2h / mois partagées</li>
            <li>Facturation entreprise</li>
            <li>Support prioritaire</li>
          </ul>
          <a href="https://rdv.webinti.com/tim/parlons-de-votre-projet" target="_blank" rel="noopener" class="price-cta">Nous contacter</a>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="sec" id="process">
  <div class="container">
    <div class="sec-head">
      <div class="sec-kicker">Méthode</div>
      <h2 class="sec-title">4 étapes, zéro surprise.</h2>
      <p class="sec-lede">Un process carré, des jalons clairs, une communication hebdomadaire.</p>
    </div>
    <div class="steps">
    <div class="step">
      <div class="step-t">Évaluation</div>
      <div class="step-d">Audit de niveau et définition des objectifs.</div>
    </div>
    <div class="step">
      <div class="step-t">Parcours</div>
      <div class="step-d">Modules théoriques + exercices pratiques.</div>
    </div>
    <div class="step">
      <div class="step-t">Projet</div>
      <div class="step-d">Construction d'un produit réel pendant la formation.</div>
    </div>
    <div class="step">
      <div class="step-t">Certification</div>
      <div class="step-d">Évaluation finale + attestation de formation.</div>
    </div></div>
  </div>
</section>

<section class="sec">
  <div class="container">
    <div class="sec-head">
      <div class="sec-kicker">FAQ</div>
      <h2 class="sec-title">Questions fréquentes.</h2>
    </div>
    <div class="faq">
    <details class="faq-item">
      <summary class="faq-q">Les formations sont-elles finançables ?</summary>
      <div class="faq-a">Oui, via nos organismes partenaires certifiés Qualiopi : Illith et La Strat. Le financement OPCO et le plan de développement des compétences passent par eux. Parlez-nous de votre projet pour qu'on vous oriente vers la bonne structure.</div>
    </details>
    <details class="faq-item">
      <summary class="faq-q">Distanciel ou présentiel ?</summary>
      <div class="faq-a">Les deux. Sessions en visio avec classe virtuelle, ou intra-entreprise dans vos locaux en France et Europe.</div>
    </details>
    <details class="faq-item">
      <summary class="faq-q">Quel niveau requis ?</summary>
      <div class="faq-a">Aucun prérequis technique pour les modules fondamentaux. Les cursus avancés supposent une première expérience NoCode ou produit.</div>
    </details>
    <details class="faq-item">
      <summary class="faq-q">Combien coûte une formation ?</summary>
      <div class="faq-a">Module court (12-20h) : 1200-2400€ HT par personne. Cursus complet 80h : 4900€ HT. Tarifs intra sur devis.</div>
    </details></div>
  </div>
</section>

<section class="ex-cta">
  <div class="container">
    <div class="ex-cta-inner">
      <h2>Besoin d'un expert sur votre projet ?</h2>
      <p>1h de mentoring en visio avec un dev senior. Débloquer un point dur, valider une archi, recevoir un audit produit — repartez avec des réponses concrètes.</p>
      <a href="https://rdv.webinti.com/tim/mentoring-personnalise" target="_blank" rel="noopener" class="btn btn-primary">Réserver une session de mentoring
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M9 7h8v8"/></svg>
      </a>
    </div>
  </div>
</section>

<script>
  // Pricing toggle — swap grids
  const osGrid = document.getElementById('pricing-os');
  const subGrid = document.getElementById('pricing-sub');
  document.querySelectorAll<HTMLButtonElement>('.pricing-toggle button').forEach((b) => {
    b.addEventListener('click', () => {
      document.querySelectorAll('.pricing-toggle button').forEach((x) => x.classList.remove('active'));
      b.classList.add('active');
      const tab = b.dataset.tab;
      if (osGrid && subGrid) {
        (osGrid as HTMLElement).hidden = tab !== 'oneshot';
        (subGrid as HTMLElement).hidden = tab !== 'sub';
      }
    });
  });

  // Formations tab filter
  document.querySelectorAll<HTMLButtonElement>('.form-tabs button').forEach((b) => {
    b.addEventListener('click', () => {
      document.querySelectorAll('.form-tabs button').forEach((x) => x.classList.remove('active'));
      b.classList.add('active');
      const cat = b.dataset.cat;
      document.querySelectorAll<HTMLElement>('.formation').forEach((f) => {
        if (cat === 'all' || f.dataset.cat === cat) f.classList.remove('hidden');
        else f.classList.add('hidden');
      });
    });
  });
</script>
</ExpertiseLayout>
