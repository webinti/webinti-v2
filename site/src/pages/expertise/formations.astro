---
import ExpertiseLayout from '../../layouts/ExpertiseLayout.astro';

const faqs = [
  {
    "q": "Les formations sont-elles finançables ?",
    "a": "Oui, via nos organismes partenaires certifiés Qualiopi : Illith et La Strat. Le financement OPCO et le plan de développement des compétences passent par eux. Parlez-nous de votre projet pour qu'on vous oriente vers la bonne structure."
  },
  {
    "q": "Distanciel ou présentiel ?",
    "a": "Les deux. Sessions en visio avec classe virtuelle, ou intra-entreprise dans vos locaux en France et Europe."
  },
  {
    "q": "Quel niveau requis ?",
    "a": "Aucun prérequis technique pour les modules fondamentaux. Les cursus avancés supposent une première expérience NoCode ou produit."
  },
  {
    "q": "Combien coûte une formation ?",
    "a": "Module court (12-20h) : 1200-2400€ HT par personne. Cursus complet 80h : 4900€ HT. Tarifs intra sur devis."
  }
];
---
<ExpertiseLayout
  title="Formations — Webinti"
  description="+ de 110 heures de formation pour développer votre projet. Cursus Bubble, FlutterFlow, n8n et IA, animés par des praticiens en activité."
  canonical="https://webinti.com/expertise/formations/"
  serviceName="Webinti — Formations"
  faqs={faqs}
>
<section class="ex-hero">
  <div class="ex-hero-bg"><div class="ex-hero-grid"></div></div>
  <div class="container">
    <div class="ex-hero-inner">
      <nav class="crumb" aria-label="Fil d'Ariane">
        <a href="/">Accueil</a>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
        <a href="/expertise/developpement-web/">Expertise</a>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
        <span>Formations</span>
      </nav>
      <div class="ex-eyebrow"><span class="dot"></span>Financement possible via Illith & La Strat</div>
      <h1 class="ex-title"><em>Formations</em><br>pensé pour livrer vite.</h1>
      <p class="ex-sub">+ de 110 heures de formation pour développer votre projet. Cursus Bubble, FlutterFlow, n8n et IA, animés par des praticiens en activité.</p>
      <div class="ex-cta-row">
        <a href="https://rdv.webinti.com/tim/parlons-de-votre-projet" target="_blank" rel="noopener" class="btn btn-primary">Parler à un expert
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M9 7h8v8"/></svg>
        </a>
        <a href="#process" class="btn btn-ghost">Voir la méthode</a>
      </div>
      <div class="ex-meta">
    <div class="ex-meta-item">
      <span class="ex-meta-label">Heures de formation</span>
      <span class="ex-meta-value">+110 heures</span>
    </div>
    <div class="ex-meta-item">
      <span class="ex-meta-label">Format</span>
      <span class="ex-meta-value">Distanciel · Intra</span>
    </div>
    <div class="ex-meta-item">
      <span class="ex-meta-label">Niveau</span>
      <span class="ex-meta-value">Débutant à avancé</span>
    </div></div>
    </div>
  </div>
</section>

<section class="sec">
  <div class="container">
    <div class="sec-head">
      <div class="sec-kicker">Ce que l'on fait</div>
      <h2 class="sec-title">Un catalogue pensé pour les produits qui doivent sortir.</h2>
      <p class="sec-lede">Des briques éprouvées, que l'on combine selon votre contexte — et que l'on ajuste selon votre stack et vos contraintes.</p>
    </div>
    <div class="feat-grid">
    <div class="feat">
      <div class="feat-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><circle cx="12" cy="12" r="9"/><path d="M12 3v18"/><path d="M3 12h18"/></svg></div>
      <div class="feat-t">Bubble Fundamentals</div>
      <div class="feat-d">De zéro à production : database, workflows, responsive, API. 24h.</div>
    </div>
    <div class="feat">
      <div class="feat-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><rect x="6" y="2" width="12" height="20" rx="3"/></svg></div>
      <div class="feat-t">FlutterFlow Mastery</div>
      <div class="feat-d">Construire une app mobile complète avec backend Firebase. 20h.</div>
    </div>
    <div class="feat">
      <div class="feat-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><circle cx="6" cy="6" r="2"/><circle cx="18" cy="6" r="2"/><circle cx="12" cy="18" r="2"/><path d="M6 8v3a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2V8"/><path d="M12 13v3"/></svg></div>
      <div class="feat-t">n8n & Automation</div>
      <div class="feat-d">Orchestrer vos outils, workflows avancés, self-hosting. 16h.</div>
    </div>
    <div class="feat">
      <div class="feat-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><path d="M12 2a5 5 0 0 0-5 5c0 1.5.7 2.9 1.8 3.8A5 5 0 0 0 7 17h10a5 5 0 0 0-1.8-6.2A5 5 0 0 0 12 2z"/></svg></div>
      <div class="feat-t">IA pour NoCoders</div>
      <div class="feat-d">Prompt engineering, Claude, RAG, agents autonomes sur n8n. 12h.</div>
    </div>
    <div class="feat">
      <div class="feat-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><path d="M12 2l3 6 7 1-5 5 1 7-6-3-6 3 1-7-5-5 7-1z"/></svg></div>
      <div class="feat-t">Cursus complet</div>
      <div class="feat-d">Parcours full-stack NoCode sur 12 semaines, mentoring inclus. 80h.</div>
    </div>
    <div class="feat">
      <div class="feat-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><circle cx="9" cy="7" r="3"/><circle cx="17" cy="9" r="2.5"/><path d="M3 20a6 6 0 0 1 12 0"/><path d="M14 18a5 5 0 0 1 7 2"/></svg></div>
      <div class="feat-t">Intra-entreprise</div>
      <div class="feat-d">Formation sur-mesure pour vos équipes, dans vos locaux ou en remote.</div>
    </div></div>
  </div>
</section>

<section class="sec" id="process">
  <div class="container">
    <div class="sec-head">
      <div class="sec-kicker">Méthode</div>
      <h2 class="sec-title">4 étapes, zéro surprise.</h2>
      <p class="sec-lede">Un process carré, des jalons clairs, une communication hebdomadaire.</p>
    </div>
    <div class="steps">
    <div class="step">
      <div class="step-t">Évaluation</div>
      <div class="step-d">Audit de niveau et définition des objectifs.</div>
    </div>
    <div class="step">
      <div class="step-t">Parcours</div>
      <div class="step-d">Modules théoriques + exercices pratiques.</div>
    </div>
    <div class="step">
      <div class="step-t">Projet</div>
      <div class="step-d">Construction d'un produit réel pendant la formation.</div>
    </div>
    <div class="step">
      <div class="step-t">Certification</div>
      <div class="step-d">Évaluation finale + attestation de formation.</div>
    </div></div>
  </div>
</section>

<section class="sec">
  <div class="container">
    <div class="sec-head">
      <div class="sec-kicker">Stack</div>
      <h2 class="sec-title">Les bons outils pour le bon projet.</h2>
      <p class="sec-lede">Nous choisissons la stack en fonction de vos contraintes — pas l'inverse.</p>
    </div>
    <div class="tools-strip"><span class="tool-chip"><span class="tool-dot"></span>Bubble</span><span class="tool-chip"><span class="tool-dot"></span>FlutterFlow</span><span class="tool-chip"><span class="tool-dot"></span>n8n</span><span class="tool-chip"><span class="tool-dot"></span>Claude</span><span class="tool-chip"><span class="tool-dot"></span>Figma</span><span class="tool-chip"><span class="tool-dot"></span>Supabase</span><span class="tool-chip"><span class="tool-dot"></span>Airtable</span></div>
  </div>
</section>

<section class="sec">
  <div class="container">
    <div class="sec-head">
      <div class="sec-kicker">FAQ</div>
      <h2 class="sec-title">Questions fréquentes.</h2>
    </div>
    <div class="faq">
    <details class="faq-item">
      <summary class="faq-q">Les formations sont-elles finançables ?</summary>
      <div class="faq-a">Oui, via nos organismes partenaires certifiés Qualiopi : Illith et La Strat. Le financement OPCO et le plan de développement des compétences passent par eux. Parlez-nous de votre projet pour qu'on vous oriente vers la bonne structure.</div>
    </details>
    <details class="faq-item">
      <summary class="faq-q">Distanciel ou présentiel ?</summary>
      <div class="faq-a">Les deux. Sessions en visio avec classe virtuelle, ou intra-entreprise dans vos locaux en France et Europe.</div>
    </details>
    <details class="faq-item">
      <summary class="faq-q">Quel niveau requis ?</summary>
      <div class="faq-a">Aucun prérequis technique pour les modules fondamentaux. Les cursus avancés supposent une première expérience NoCode ou produit.</div>
    </details>
    <details class="faq-item">
      <summary class="faq-q">Combien coûte une formation ?</summary>
      <div class="faq-a">Module court (12-20h) : 1200-2400€ HT par personne. Cursus complet 80h : 4900€ HT. Tarifs intra sur devis.</div>
    </details></div>
  </div>
</section>

<section class="ex-cta">
  <div class="container">
    <div class="ex-cta-inner">
      <h2>Parlons de votre projet.</h2>
      <p>30 minutes en visio pour cadrer votre besoin, estimer le budget, et repartir avec un plan clair.</p>
      <a href="https://rdv.webinti.com/tim/parlons-de-votre-projet" target="_blank" rel="noopener" class="btn btn-primary">Réserver un créneau
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M9 7h8v8"/></svg>
      </a>
    </div>
  </div>
</section>
</ExpertiseLayout>
